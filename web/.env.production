# 2026-04-17 新增 — 环境区分任务 1：Web 端 production 契约冻结
# 变更类型：新增/配置
# 功能描述：为 web 生产构建冻结线上基准地址，确保发布产物默认指向受控 zhiz.chat 域名体系。
# 设计思路：
#   1. 使用与 development 同名的 `VITE_` 语义变量，保证后续任务 3 的消费逻辑无需分叉命名。
#   2. 保留 `VITE_API_BASE` 作为当前/过渡期兼容别名，避免在任务 1 提前触碰运行时代码。
#   3. 生产构建明确指向 `https://api.zhiz.chat` / `https://prompt.zhiz.chat` / `https://zhiz.chat`，为后续 localhost 泄漏门禁提供基线。
# 参数与返回值：以下均为 Vite build-time 环境变量，无运行时返回值。
# 影响范围：web 生产构建 env 注入、后续 backend/skill/SSO 链路接线与发布门禁。
# 潜在风险：若后续运行时代码未完成切换，当前仍主要由 `VITE_API_BASE` 承接兼容读取。
VITE_APP_ENV=production
VITE_BACKEND_PUBLIC_BASE_URL=https://api.zhiz.chat
VITE_WEB_PUBLIC_BASE_URL=https://prompt.zhiz.chat
VITE_WEB_HUB_PUBLIC_BASE_URL=https://zhiz.chat
VITE_SSO_HUB_BASE_URL=https://zhiz.chat
VITE_API_BASE=https://api.zhiz.chat
