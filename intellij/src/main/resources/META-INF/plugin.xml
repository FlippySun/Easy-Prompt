<idea-plugin>
    <id>com.easyprompt.plugin</id>
    <name>Easy Prompt</name>
    <vendor>Easy Prompt</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="com.easyprompt.settings.EasyPromptConfigurable"
                id="com.easyprompt.settings"
                displayName="Easy Prompt"/>
        <applicationService
                serviceImplementation="com.easyprompt.settings.EasyPromptSettings"/>
        <notificationGroup id="Easy Prompt"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
        <postStartupActivity
                implementation="com.easyprompt.ui.WelcomeStartupActivity"/>
        <statusBarWidgetFactory
                id="EasyPrompt.StatusBar"
                implementation="com.easyprompt.ui.EasyPromptStatusBarWidgetFactory"
                order="after encodingWidget"/>

        <toolWindow
            id="Easy Prompt"
            anchor="right"
            icon="/icons/easyPromptToolWindow.svg"
            factoryClass="com.easyprompt.ui.EasyPromptToolWindowFactory"/>
    </extensions>

    <actions>
        <group id="EasyPrompt.Group" text="Easy Prompt" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="EasyPrompt.EnhanceSelected"
                    class="com.easyprompt.actions.EnhanceSelectedAction"
                    text="Easy Prompt：增强选中文本"
                    description="将选中文本通过 AI 智能增强为专业 Prompt">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt P"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt P"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt P"/>
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>

            <action id="EasyPrompt.SmartEnhance"
                    class="com.easyprompt.actions.SmartEnhanceAction"
                    text="Easy Prompt：智能增强"
                    description="自动判断增强选中/文件/剪贴板内容，无需手动选择">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt I"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt I"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt I"/>
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>

            <action id="EasyPrompt.EnhanceInput"
                    class="com.easyprompt.actions.EnhanceInputAction"
                    text="快速输入增强"
                    description="通过输入框输入文本进行 AI Prompt 增强">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt O"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt O"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt O"/>
            </action>

            <action id="EasyPrompt.ShowScenes"
                    class="com.easyprompt.actions.ShowScenesAction"
                    text="浏览场景列表"
                    description="查看所有可用的 Prompt 增强场景">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt L"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt L"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt L"/>
            </action>

            <action id="EasyPrompt.EnhanceWithScene"
                    class="com.easyprompt.actions.EnhanceWithSceneAction"
                    text="指定场景增强"
                    description="手动选择场景进行精准定向 Prompt 增强">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt M"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt M"/>
            </action>

            <action id="EasyPrompt.ShowWelcome"
                    class="com.easyprompt.actions.ShowWelcomeAction"
                    text="查看使用教程"
                    description="显示 Easy Prompt 使用教程和场景列表">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt H"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt H"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt H"/>
            </action>

            <action id="EasyPrompt.ShowHistory"
                    class="com.easyprompt.actions.ShowHistoryAction"
                    text="查看增强历史"
                    description="查看 Prompt 增强历史记录，支持对比和复制">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt Y"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="ctrl alt Y"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="ctrl alt Y"/>
            </action>

            <action id="EasyPrompt.StatusBarMenu"
                    class="com.easyprompt.actions.StatusBarMenuAction"
                    text="打开快捷菜单"
                    description="显示 Easy Prompt 快捷操作菜单"/>

            <!-- 2026-04-10 B7: SSO 登录/退出 Actions -->
            <action id="EasyPrompt.Login"
                    class="com.easyprompt.actions.LoginAction"
                    text="登录 zhiz.chat"
                    description="通过 SSO 登录 zhiz.chat 账号"/>

            <action id="EasyPrompt.Logout"
                    class="com.easyprompt.actions.LogoutAction"
                    text="退出登录"
                    description="退出 zhiz.chat SSO 登录"/>
        </group>

        <!--
          2026-04-10
          变更类型：新增
          功能描述：在 IntelliJ IDEA 启动 Welcome Screen 提供 zhiz.chat 登录快捷入口。
          设计思路：使用无项目依赖的 WelcomeScreenLoginAction 复用 SsoAuthClient.startLogin()，
          避免 ShowWelcomeAction 在无 project 上下文时失效。
          影响范围：IDE 启动 Welcome Screen 的 Quick Start 区域、SSO 登录入口发现路径。
          潜在风险：若 JetBrains Welcome Screen 分组 ID 在未来 SDK 版本调整，需要同步此注册；无已知风险。
        -->
        <action id="EasyPrompt.WelcomeScreenLogin"
                class="com.easyprompt.actions.WelcomeScreenLoginAction"
                text="登录 zhiz.chat"
                description="在 IDEA 启动欢迎页中直接发起 zhiz.chat SSO 登录">
            <add-to-group group-id="WelcomeScreen.QuickStart.Platform" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
