# 2026-04-17 新增 — 环境区分任务 1：Browser 端 production 契约冻结
# 变更类型：新增/配置
# 功能描述：为 browser 正式 build/zip 产物冻结线上基准地址，供后续任务 5 通过 WXT build-time env 注入消费。
# 设计思路：
#   1. 使用 WXT 官方支持的 `WXT_` 前缀，和 development 保持同名语义，避免后续读取逻辑分叉。
#   2. 明确生产基准地址属于 A 类 app 资产；Browser 的真实 redirect/callback 机制仍按 chromiumapp.org / extension scheme / Safari / Firefox 机制单独处理。
#   3. 生产构建锁定 `api.zhiz.chat` / `prompt.zhiz.chat` / `zhiz.chat`，为后续构建产物 localhost 泄漏门禁提供标准答案。
# 参数与返回值：以下均为 WXT build-time 环境变量，无运行时返回值。
# 影响范围：browser/shared/api.js、browser/shared/sso.js、content/options/E2E 的后续环境接线与发布门禁。
# 潜在风险：任务 1 仅冻结契约；实际读取与测试切换将在任务 5 落地。
WXT_APP_ENV=production
WXT_BACKEND_PUBLIC_BASE_URL=https://api.zhiz.chat
WXT_WEB_PUBLIC_BASE_URL=https://prompt.zhiz.chat
WXT_WEB_HUB_PUBLIC_BASE_URL=https://zhiz.chat
WXT_SSO_HUB_BASE_URL=https://zhiz.chat
WXT_ZHIZ_SKILLS_MANAGER_URL="https://zhiz.me/chat-flow/#/skills/index"
